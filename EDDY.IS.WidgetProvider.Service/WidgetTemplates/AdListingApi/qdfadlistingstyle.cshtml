@model EDDY.IS.WidgetProvider.Core.Entities.AdListingApiPlacement

<div class='eddy-qdf-listing'>
@foreach (var adItem in Model.AdItemList)
{
    <div class='item-wrapper'>
        <a class='item' href='@adItem.ClickUrl' target='_blank'>
            <div class='item-info'>
                <h3>@adItem.InstitutionName</h3>
                <div class='item-desc'>
                    @System.Web.HttpUtility.HtmlDecode(adItem.Description)
                </div>
            </div>
            <div class='item-img'>
                <img src='@adItem.LargeLogoUrl' loading='lazy' alt='@adItem.InstitutionName' width='190' height='63'>
                <div class='item-btn @(!adItem.IsLeadUrl ? "isClick" : string.Empty)'>
                    <buttonText></buttonText>
                </div>
                <span class='item-link'>Find your degree program</span>
            </div>
        </a>
    </div>
}
</div>