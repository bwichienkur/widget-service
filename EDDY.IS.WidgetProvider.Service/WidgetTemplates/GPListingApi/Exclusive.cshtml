@model EDDY.IS.WidgetProvider.Core.Entities.GPListingApiPlacement

<div class='eddy-qdf-listing'>
    @foreach (var adItem in Model.AdItemList)
    {
        <div class='item-wrapper'>
            <a class='item' href='@adItem.ClickThroughUrl' target='_blank' rel='nofollow'>

                <div class='item-header'>
                    <div class='header-band'>
                        <div class='call-out-mobile'>
                            @Html.Raw(adItem.PopularPrograms.EscapeContent())
                        </div>
                    </div>
                    <div class='item-headline'>@adItem.Header</div>
                    <div class='header-online'>Online</div>
                </div>
                <div class='item-content'>
                    <div class='item-info'>
                        <div class='item-desc'>
                            @Html.Raw(adItem.Description.EscapeContent())
                        </div>
                    </div>
                    <div class='item-img'>
                        <div class='school-logo'>
                            <img src='@adItem.LogoSmallImage' loading='lazy' alt='@adItem.Header.RemoveSingleQuote()' width='190' height='63'>
                        </div>
                        @*<div class='item-btn @(!adItem.IsLeadUrl ? 'isClick' : string.Empty)'>*@
                        <div class='item-btn'>
                            <buttonText>Start Here</buttonText>
                        </div>
                        <span class='item-link'>@adItem.DisplayUrl</span>
                        <div class='call-out'>
                            @Html.Raw(adItem.PopularPrograms.EscapeContent())
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>
